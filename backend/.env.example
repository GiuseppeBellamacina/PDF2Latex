# ── PDF2LaTeX secrets ──────────────────────────────────────────────────
# Copy this file to .env and fill in the encryption key.
# Non-sensitive settings belong in config.yaml (at the repo root).
# Prefix all vars with PDF2TEX_.

# Encryption key for API keys stored in DB (REQUIRED for production).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# PDF2TEX_ENCRYPTION_KEY=
