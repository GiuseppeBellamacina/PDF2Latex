# ---- Server ----
PDF2TEX_HOST=0.0.0.0
PDF2TEX_PORT=8000
PDF2TEX_DEBUG=false

# Encryption key used to encrypt provider API keys stored in the DB.
# Change this to a long random string in production.
PDF2TEX_ENCRYPTION_KEY=change-me-to-a-long-random-secret

# ---- LaTeX ----
# Path to the pdflatex binary (leave as "pdflatex" if on PATH). Set empty to skip compilation.
PDF2TEX_PDFLATEX_BIN=pdflatex
PDF2TEX_LATEX_COMPILE_PASSES=2

# ---- PDF extraction ----
# Backend used to extract content: pymupdf | docling | markitdown
PDF2TEX_EXTRACTOR_BACKEND=pymupdf
# Run OCR on pages with little/no extractable text (requires the "ocr" extra + tesseract)
PDF2TEX_ENABLE_OCR=false
# DPI used to render slides/pages to PNG
PDF2TEX_RENDER_DPI=130

# ---- Defaults (overridable per project from the UI) ----
PDF2TEX_DEFAULT_LANGUAGE=italian
