# PDF2LaTeX — Environment configuration
# Copy to .env and fill in your values:  cp .env.example .env
# All variables are prefixed with PDF2TEX_ (set by config.py).

# ── Security (REQUIRED) ─────────────────────────────────────────────────
# Fernet key for encrypting API keys stored in the local SQLite DB.
# Generate one with:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PDF2TEX_ENCRYPTION_KEY=

# ── App ─────────────────────────────────────────────────────────────────
# PDF2TEX_APP_NAME=PDF2LaTeX

# ── Network ─────────────────────────────────────────────────────────────
# PDF2TEX_HOST=0.0.0.0
# PDF2TEX_PORT=8000
# PDF2TEX_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Logging ─────────────────────────────────────────────────────────────
# PDF2TEX_LOG_LEVEL=INFO        # DEBUG | INFO | WARNING | ERROR
# PDF2TEX_LOG_TO_FILE=true
# PDF2TEX_DEBUG=false

# ── Storage (defaults: ./storage/… under the backend directory) ─────────
# Rarely overridden — the app auto-creates ./storage/{uploads,output,cache}
# and ./storage/app.db relative to the backend/ working directory.
# PDF2TEX_DATA_DIR=./storage
# PDF2TEX_UPLOADS_DIR=./storage/uploads
# PDF2TEX_OUTPUT_DIR=./storage/output
# PDF2TEX_CACHE_DIR=./storage/cache
# PDF2TEX_DB_PATH=./storage/app.db

# ── LaTeX compilation ───────────────────────────────────────────────────
# PDF2TEX_PDFLATEX_BIN=pdflatex
# PDF2TEX_BIBTEX_BIN=bibtex
# PDF2TEX_LATEX_COMPILE_PASSES=2
# PDF2TEX_LATEX_LINT=true         # deterministic repair pass before pdflatex
# PDF2TEX_LATEX_TEMPLATE=default  # default | paper | thesis-oneside | thesis-twoside

# ── PDF extraction ──────────────────────────────────────────────────────
# PDF2TEX_OCR_LANG=ita+eng              # tesseract language(s), '+' to combine
# PDF2TEX_TESSERACT_CMD=                 # explicit path to tesseract.exe (empty = auto-detect)
# PDF2TEX_RENDER_DPI=130
# PDF2TEX_DOCLING_MAX_PAGES=200         # skip Docling above this page count
# PDF2TEX_DOCLING_CHUNK_PAGES=8         # pages per isolated Docling subprocess
# PDF2TEX_DOCLING_ENABLE_TABLES=true    # recover tables as structured markdown
# PDF2TEX_DOCLING_SUBPROCESS_TIMEOUT=600  # seconds per chunk
# PDF2TEX_EXTRACTION_CACHE=true         # cache Docling markdown by file hash
# PDF2TEX_DEDUP_HEADERS_FOOTERS=true    # strip recurring page headers/footers

# ── LLM orchestration ───────────────────────────────────────────────────
# PDF2TEX_LLM_MAX_CONCURRENCY=4       # max simultaneous LLM calls
# PDF2TEX_LLM_MAX_RETRIES=4           # retries on transient errors (429/5xx/timeout)
# PDF2TEX_LLM_RETRY_BASE_DELAY=1.5    # seconds; exponential backoff base
# PDF2TEX_LLM_REQUEST_TIMEOUT=180     # seconds per LLM call

# ── Per-role LLM temperatures ───────────────────────────────────────────
# PDF2TEX_ANALYZER_TEMPERATURE=0.0
# PDF2TEX_PLANNER_TEMPERATURE=0.1
# PDF2TEX_WRITER_TEMPERATURE=0.3
# PDF2TEX_REVIEWER_TEMPERATURE=0.0
# PDF2TEX_JUDGE_TEMPERATURE=0.0

# ── LLM token / char budgets ────────────────────────────────────────────
# PDF2TEX_ANALYZER_CHUNK_CHARS=16000     # map-reduce chunk size for long docs
# PDF2TEX_ANALYZER_MAX_CHUNKS=12         # safety cap on chunks per document
# PDF2TEX_WRITER_SOURCE_CHARS=14000      # relevance-selected source budget per section
# PDF2TEX_WRITER_MAX_SOURCE_CHARS=50000  # total cap when many sources (0 = no cap)
# PDF2TEX_WRITER_EXPAND_THRESHOLD=600    # char threshold to auto-expand thin sections
# PDF2TEX_WRITER_USE_KNOWLEDGE=false     # let writer supplement with internal LLM knowledge

# ── Quality checks (diamond-parallel, best-effort) ──────────────────────
# PDF2TEX_COHERENCE_ENABLED=true      # cross-chapter contradiction & terminology check
# PDF2TEX_CITATIONS_ENABLED=true      # audit citation compliance

# ── Structural judge ────────────────────────────────────────────────────
# PDF2TEX_JUDGE_ENABLED=true          # enable post-compile structural evaluation
# PDF2TEX_JUDGE_MAX_ITERATIONS=1      # max structural revision rounds
# PDF2TEX_JUDGE_LAYOUT_INSPECT=true   # deterministic PDF layout analysis (overfull boxes, figure sizing)
# PDF2TEX_JUDGE_VISION=false          # vision-capable model review of rendered pages (requires multimodal LLM)
# PDF2TEX_JUDGE_VISION_MAX_PAGES=12   # cap pages sent to vision model
# PDF2TEX_JUDGE_VISION_DPI=110        # render DPI for judged page images

# ── Figures ─────────────────────────────────────────────────────────────
# PDF2TEX_MAX_FIGURES_PER_SECTION=4      # hard cap of figures per section
# PDF2TEX_FIGURE_WIDTH_RATIO=0.62        # \includegraphics width as fraction of \linewidth
# PDF2TEX_FIGURE_MAX_HEIGHT_RATIO=0.42   # cap height as fraction of \textheight

# ── Chapter overview ────────────────────────────────────────────────────
# PDF2TEX_OVERVIEW_ENABLED=true        # prepend chapter synopses page after ToC
# PDF2TEX_OVERVIEW_MIN_CHAPTERS=3      # also triggered when merging >1 source

# ── Web research (research-based generation, no PDF needed) ─────────────
# PDF2TEX_RESEARCH_MAX_QUERIES=5             # max parallel search queries per research run
# PDF2TEX_RESEARCH_RESULTS_PER_QUERY=5       # top results to consider per query
# PDF2TEX_RESEARCH_FETCH_PAGES=true          # fetch full page content (not just snippets)
# PDF2TEX_RESEARCH_MAX_FETCH_CONCURRENCY=4   # max simultaneous page fetches
# PDF2TEX_RESEARCH_PAGE_MAX_CHARS=8000       # cap fetched page text for LLM budgets
