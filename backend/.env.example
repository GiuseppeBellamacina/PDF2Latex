# ---- Server ----
PDF2TEX_HOST=0.0.0.0
PDF2TEX_PORT=8000
PDF2TEX_DEBUG=false

# Encryption key used to encrypt provider API keys stored in the DB.
# Change this to a long random string in production.
PDF2TEX_ENCRYPTION_KEY=change-me-to-a-long-random-secret

# ---- Logging ----
# DEBUG | INFO | WARNING | ERROR
PDF2TEX_LOG_LEVEL=INFO
# Also write logs to storage/pdf2latex.log (rotating)
PDF2TEX_LOG_TO_FILE=true

# ---- LaTeX ----
# Path to the pdflatex binary (leave as "pdflatex" if on PATH). Set empty to skip compilation.
PDF2TEX_PDFLATEX_BIN=pdflatex
PDF2TEX_LATEX_COMPILE_PASSES=2
# Deterministic LaTeX repair pass (balance braces/environments) before pdflatex
PDF2TEX_LATEX_LINT=true

# ---- PDF extraction ----
# Backend used to extract content: hybrid | pymupdf | docling
#   hybrid  = Docling structured text + PyMuPDF figures + OCR fallback (recommended)
#   pymupdf = fast, text + figures only
#   docling = structured text only
PDF2TEX_EXTRACTOR_BACKEND=hybrid
# Run OCR on image-only pages (requires the "ocr" extra AND the Tesseract binary on PATH)
PDF2TEX_ENABLE_OCR=false
# Tesseract language(s); combine with '+', e.g. ita+eng. Install the matching language packs.
PDF2TEX_OCR_LANG=ita+eng
# Path to tesseract.exe. Leave empty to auto-detect (PATH + standard install dirs).
# Set it if auto-detection fails, e.g. C:\Program Files\Tesseract-OCR\tesseract.exe
PDF2TEX_TESSERACT_CMD=
# DPI used to render pages to PNG (for OCR / vision)
PDF2TEX_RENDER_DPI=130

# ---- Docling (isolated, chunked, cached) ----
# Skip Docling entirely above this page count (uses PyMuPDF text instead)
PDF2TEX_DOCLING_MAX_PAGES=200
# Pages per isolated Docling subprocess (smaller = less memory)
PDF2TEX_DOCLING_CHUNK_PAGES=8
# Recover tables as structured markdown
PDF2TEX_DOCLING_ENABLE_TABLES=true
# Seconds per chunk before giving up
PDF2TEX_DOCLING_SUBPROCESS_TIMEOUT=600
# Cache Docling markdown by file hash
PDF2TEX_EXTRACTION_CACHE=true
# Strip recurring page headers/footers from extracted text
PDF2TEX_DEDUP_HEADERS_FOOTERS=true

# ---- LLM orchestration ----
PDF2TEX_LLM_MAX_CONCURRENCY=4
PDF2TEX_LLM_MAX_RETRIES=4
PDF2TEX_LLM_RETRY_BASE_DELAY=1.5
PDF2TEX_LLM_REQUEST_TIMEOUT=180
# Per-role sampling temperatures
PDF2TEX_ANALYZER_TEMPERATURE=0.0
PDF2TEX_PLANNER_TEMPERATURE=0.1
PDF2TEX_WRITER_TEMPERATURE=0.3
PDF2TEX_REVIEWER_TEMPERATURE=0.0
PDF2TEX_JUDGE_TEMPERATURE=0.0
# Char budgets (avoid silent truncation)
PDF2TEX_ANALYZER_CHUNK_CHARS=16000
PDF2TEX_ANALYZER_MAX_CHUNKS=12
PDF2TEX_WRITER_SOURCE_CHARS=14000

# ---- Figures ----
# Hard cap of figures rendered per section
PDF2TEX_MAX_FIGURES_PER_SECTION=4
# \includegraphics width as a fraction of the line width
PDF2TEX_FIGURE_WIDTH_RATIO=0.62
# Cap figure height as a fraction of \textheight
PDF2TEX_FIGURE_MAX_HEIGHT_RATIO=0.42

# ---- Judge (post-compile review) ----
# Enable the judge phase that reviews the compiled document and may request a revision
PDF2TEX_JUDGE_ENABLED=true
# How many structural-revision rounds are allowed after the first PDF
PDF2TEX_JUDGE_MAX_ITERATIONS=1
# Deterministic layout inspection (no LLM / no multimodal): measures the PDF
# (oversized/clustered figures, near-empty pages) + reads the pdflatex log for
# overfull boxes, and feeds these concrete facts to the judge. Works everywhere.
PDF2TEX_JUDGE_LAYOUT_INSPECT=true
# Optional vision review: render the PDF pages and let a *vision-capable* model
# (gpt-4o, claude-3.5, ...) look at them. Leave false if you don't have one.
PDF2TEX_JUDGE_VISION=false
# Max pages sent to the vision model (cost control)
PDF2TEX_JUDGE_VISION_MAX_PAGES=12
# Render DPI for the judged page images
PDF2TEX_JUDGE_VISION_DPI=110

# ---- Defaults (overridable per project from the UI) ----
PDF2TEX_DEFAULT_LANGUAGE=english
